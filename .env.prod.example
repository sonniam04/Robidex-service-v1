# Copy to .env.prod — NEVER commit .env.prod to git
# Generate secrets with: openssl rand -base64 48

DB_PASSWORD=use_a_strong_random_password_here
JWT_SECRET=use_a_64_character_random_string_here

# Domain config
SITE_URL=https://robidex.app
API_URL=https://api.robidex.app

# Used ONLY during first-time setup (see DEPLOY.md step 5)
# Remove from .env.prod after running setup-admin
ADMIN_EMAIL=admin@robidex.app
ADMIN_PASSWORD=ChangeThisToAStrongPassword123!
